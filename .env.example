OPENAI_API_KEY=sk-proj-your-key
OPENAI_MODEL=gpt-5.5
PORT=3000
BASE_PATH=/Miele.DevPilot

# Optional: configure the current model prices in USD per 1M tokens
# so project-level OpenAI costs can be estimated from API usage.
OPENAI_INPUT_USD_PER_1M_TOKENS=
OPENAI_CACHED_INPUT_USD_PER_1M_TOKENS=
OPENAI_OUTPUT_USD_PER_1M_TOKENS=

# Set this to true when you want to test the Excel workflow without API calls.
OPENAI_MOCK=false
