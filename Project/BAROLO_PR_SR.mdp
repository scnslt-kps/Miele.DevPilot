    "softwareRequirements": [
      {
        "sourceRowNumber": 2,
        "sourceId": "PR_BAROLO_1.1",
        "id": "SR_BAROLO_1.1",
        "text": "The app shall display the appliance type for each connected appliance on the dashboard.",
        "happyFlow": "When the dashboard is opened and connected appliances are available, the app displays a dashboard entry for each connected appliance with its appliance type.",
        "alternativeFlows": [
          "If multiple connected appliances are shown, the app displays the appliance type separately for each appliance entry."
        ],
        "exceptionFlows": [
          "If the dashboard cannot load connected appliance data, no appliance type shall be shown as belonging to an appliance for which the data was not loaded."
        ],
        "acceptanceCriteria": [
          "Given at least one connected appliance exists, when the user opens the dashboard, then each connected appliance entry displays an appliance type.",
          "Given multiple connected appliances exist, when the dashboard is displayed, then the appliance type is visibly associated with the correct appliance entry.",
          "Given appliance data is refreshed, when the appliance type value changes in the data source, then the dashboard displays the updated appliance type after the refresh completes.",
          "Given connected appliance data cannot be loaded, when the dashboard is displayed, then the app does not display a type value for a non-loaded appliance as if it were valid."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived directly from the PR as one atomic display requirement covering the observable dashboard output and traceable per-appliance association."
      },
      {
        "sourceRowNumber": 3,
        "sourceId": "PR_BAROLO_1.2",
        "id": "SR_BAROLO_1.2",
        "text": "The app shall display the current high-level status for each connected appliance on the dashboard.",
        "happyFlow": "When the dashboard is opened and status data is available, the app displays the current high-level status for each connected appliance.",
        "alternativeFlows": [
          "If connected appliances have different statuses, the app displays the corresponding status for each appliance entry."
        ],
        "exceptionFlows": [
          "If status data for a connected appliance cannot be loaded, the app shall not display a stale or unrelated status as the current status for that appliance."
        ],
        "acceptanceCriteria": [
          "Given connected appliances exist and status data is available, when the user opens the dashboard, then each connected appliance entry displays one current high-level status.",
          "Given the status data source reports a connected appliance as available, operating normally, or requiring attention, when the dashboard is displayed, then the displayed status for that appliance matches the reported high-level status.",
          "Given multiple connected appliances exist, when the dashboard is displayed, then each status is visibly associated with the correct appliance entry.",
          "Given status data for an appliance is refreshed, when the reported high-level status changes, then the dashboard displays the updated status after the refresh completes.",
          "Given status data for an appliance cannot be loaded, when the dashboard is displayed, then the app does not present an unrelated appliance status as the current status for that appliance."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as a single atomic dashboard status display requirement with measurable correctness against the status data source."
      },
      {
        "sourceRowNumber": 4,
        "sourceId": "PR_BAROLO_2.1",
        "id": "SR_BAROLO_2.1",
        "text": "The app shall display the current temperature and unit of measure for each temperature-controlled zone of each connected appliance on the dashboard.",
        "happyFlow": "When the dashboard is opened and temperature data is available, the app displays the current temperature and unit for every temperature-controlled zone of every connected appliance.",
        "alternativeFlows": [
          "If a connected appliance has multiple temperature-controlled zones, the app displays a separate current temperature with unit for each zone.",
          "If different zones report different units of measure, the app displays the unit associated with each zone value."
        ],
        "exceptionFlows": [
          "If current temperature data for a zone cannot be loaded, the app shall not display an unrelated temperature as the current temperature for that zone."
        ],
        "acceptanceCriteria": [
          "Given a connected appliance has one temperature-controlled zone with available temperature data, when the dashboard is displayed, then that zone shows its current temperature and unit of measure.",
          "Given a connected appliance has multiple temperature-controlled zones, when the dashboard is displayed, then each temperature-controlled zone shows a separate current temperature and unit of measure.",
          "Given multiple connected appliances have temperature-controlled zones, when the dashboard is displayed, then each displayed temperature is associated with the correct appliance and zone.",
          "Given the current temperature data source provides a value and unit for a zone, when the dashboard is displayed, then the displayed value and unit match the data source after loading completes.",
          "Given current temperature data for a zone cannot be loaded, when the dashboard is displayed, then the app does not display an unrelated zone temperature as the current temperature for that zone."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as one cohesive display requirement because the temperature value and unit form one verifiable information item for each zone."
      },
      {
        "sourceRowNumber": 5,
        "sourceId": "PR_BAROLO_3.1",
        "id": "SR_BAROLO_3.1",
        "text": "The app shall provide dashboard quick actions that allow the user to set the Presenter light of a connected appliance to On or Off.",
        "happyFlow": "When a connected appliance supports a Presenter light, the user uses the dashboard quick action to switch the light to the desired state, and the app applies that state to the appliance.",
        "alternativeFlows": [
          "If the Presenter light is currently Off, the user can switch it On from the dashboard quick action.",
          "If the Presenter light is currently On, the user can switch it Off from the dashboard quick action."
        ],
        "exceptionFlows": [
          "If the Presenter light state change fails, the app shall leave the light state unconfirmed and inform the user that the action was not completed."
        ],
        "acceptanceCriteria": [
          "Given a connected appliance supports a Presenter light, when the dashboard is displayed, then a quick action for controlling the Presenter light is available for that appliance.",
          "Given the Presenter light is Off, when the user activates the dashboard quick action to turn it On, then the app requests the Presenter light state On for the correct connected appliance.",
          "Given the Presenter light is On, when the user activates the dashboard quick action to turn it Off, then the app requests the Presenter light state Off for the correct connected appliance.",
          "Given the Presenter light state change succeeds, when the dashboard is updated, then the displayed Presenter light state reflects the requested state.",
          "Given the Presenter light state change fails, when the app receives the failure result, then the app informs the user that the action was not completed and does not confirm the requested state as active."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as one atomic dashboard quick-action control requirement covering both permitted binary states and the command failure exception."
      },
      {
        "sourceRowNumber": 6,
        "sourceId": "PR_BAROLO_2.2",
        "id": "SR_BAROLO_2.2",
        "text": "The app shall display the current temperature and unit of measure for each wine zone of the selected connected appliance on the appliance detail page.",
        "happyFlow": "When the user opens the detail page for a connected appliance with wine zones, the app displays the current temperature and unit for each wine zone.",
        "alternativeFlows": [
          "If the selected appliance has multiple wine zones, the app displays a separate current temperature with unit for each wine zone."
        ],
        "exceptionFlows": [
          "If current temperature data for a wine zone cannot be loaded, the app shall not display an unrelated temperature as the current temperature for that wine zone."
        ],
        "acceptanceCriteria": [
          "Given a selected connected appliance has one wine zone with available temperature data, when the appliance detail page is displayed, then that wine zone shows its current temperature and unit of measure.",
          "Given a selected connected appliance has multiple wine zones, when the appliance detail page is displayed, then each wine zone shows a separate current temperature and unit of measure.",
          "Given the current temperature data source provides a value and unit for a wine zone, when the appliance detail page is displayed, then the displayed value and unit match the data source after loading completes.",
          "Given current temperature data for a wine zone cannot be loaded, when the appliance detail page is displayed, then the app does not display an unrelated temperature as the current temperature for that wine zone."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as one cohesive detail-page display requirement because current temperature and unit are inseparable for user interpretation and verification."
      },
      {
        "sourceRowNumber": 7,
        "sourceId": "PR_BAROLO_2.3",
        "id": "SR_BAROLO_2.3.1",
        "text": "The app shall allow the user to select a target temperature for each available wine zone only within 5°C to 20°C in 1°C increments on the appliance detail page.",
        "happyFlow": "When the appliance detail page is opened for an appliance with available wine zones, the user can choose a permitted target temperature value for each wine zone.",
        "alternativeFlows": [
          "If the appliance has multiple available wine zones, the user can select a target temperature independently for each wine zone."
        ],
        "exceptionFlows": [
          "If a value outside 5°C to 20°C or not aligned to a 1°C increment is attempted, the app shall reject the value for target-temperature selection."
        ],
        "acceptanceCriteria": [
          "Given an available wine zone is shown on the appliance detail page, when the user selects a target temperature, then the selectable values include every integer Celsius value from 5°C through 20°C.",
          "Given an available wine zone is shown on the appliance detail page, when the user selects a target temperature, then the app allows only 1°C increment values within the range 5°C to 20°C inclusive.",
          "Given a value below 5°C is attempted, when the app validates the target temperature selection, then the value is rejected.",
          "Given a value above 20°C is attempted, when the app validates the target temperature selection, then the value is rejected.",
          "Given a non-1°C-increment value is attempted, when the app validates the target temperature selection, then the value is rejected.",
          "Given multiple available wine zones exist, when the user selects a target temperature for one wine zone, then the selection applies to that wine zone and does not change the selected value for another wine zone."
        ],
        "score": 100,
        "issues": [],
        "rationale": "The source PR contains both input constraint and adjustment behavior; this SR isolates the verifiable target-temperature selection rules."
      },
      {
        "sourceRowNumber": 7,
        "sourceId": "PR_BAROLO_2.3",
        "id": "SR_BAROLO_2.3.2",
        "text": "The app shall apply a user-selected valid target temperature to the selected wine zone of the appliance from the appliance detail page.",
        "happyFlow": "After the user selects a permitted target temperature for a wine zone, the app applies the target temperature to that specific zone.",
        "alternativeFlows": [
          "If the appliance has multiple available wine zones, the user can apply different valid target temperatures to different zones."
        ],
        "exceptionFlows": [
          "If applying the target temperature fails, the app shall inform the user that the change was not completed and shall not confirm the failed value as active."
        ],
        "acceptanceCriteria": [
          "Given the user has selected a valid target temperature for a wine zone, when the user submits the change from the appliance detail page, then the app requests that target temperature for the selected wine zone of the selected appliance.",
          "Given the appliance accepts the target temperature change, when the detail page is updated, then the target temperature shown for that wine zone matches the accepted value.",
          "Given multiple wine zones are available, when the user applies a target temperature to one wine zone, then no other wine zone target temperature is changed by that action unless separately submitted by the user.",
          "Given the target temperature change request fails, when the app receives the failure result, then the app informs the user that the change was not completed and does not confirm the failed value as the active target temperature."
        ],
        "score": 100,
        "issues": [],
        "rationale": "The source PR's adjustment goal is separated from the selection constraint so command execution, zone targeting, success, and failure are independently testable."
