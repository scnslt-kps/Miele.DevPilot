    "softwareRequirements": [
      {
        "sourceRowNumber": 2,
        "sourceId": "PR_BAROLO_1.1",
        "id": "SR_BAROLO_1.1",
        "text": "The app shall display the appliance type for each connected appliance on the dashboard.",
        "happyFlow": "When the dashboard is opened or refreshed and connected appliances are available, the app displays one dashboard entry per connected appliance with its appliance type visible.",
        "alternativeFlows": [
          "If the set of connected appliances changes after refresh or synchronization, the dashboard reflects the updated appliance list and appliance types."
        ],
        "exceptionFlows": [
          "If the appliance type for a connected appliance cannot be retrieved, the dashboard displays a clearly distinguishable unavailable or unknown type indicator for that appliance instead of leaving the type field blank."
        ],
        "acceptanceCriteria": [
          "Given the user opens the dashboard and at least one connected appliance exists, when the appliance data is loaded, then each connected appliance entry shows an appliance type value.",
          "Given multiple connected appliances exist, when the dashboard is displayed, then each appliance entry shows the appliance type belonging to that specific appliance.",
          "Given the appliance type is updated by the data source and the dashboard is refreshed or synchronized, then the displayed appliance type reflects the latest retrieved value.",
          "Given an appliance type cannot be retrieved for a connected appliance, when the dashboard is displayed, then the type area for that appliance shows an unavailable or unknown indicator and remains visually associated with that appliance entry."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived directly from the product requirement as a single atomic dashboard display requirement for appliance type visibility, with verification coverage for normal, updated, multiple-appliance, and unavailable-data cases."
      },
      {
        "sourceRowNumber": 3,
        "sourceId": "PR_BAROLO_1.2",
        "id": "SR_BAROLO_1.2",
        "text": "The app shall display the current high-level status for each connected appliance on the dashboard.",
        "happyFlow": "When the dashboard is opened or refreshed, the app displays the current high-level status for every connected appliance shown on the dashboard.",
        "alternativeFlows": [
          "If an appliance status changes after refresh or synchronization, the dashboard reflects the latest retrieved high-level status for that appliance."
        ],
        "exceptionFlows": [
          "If the current high-level status of an appliance cannot be retrieved, the dashboard displays a clearly distinguishable status-unavailable indicator for that appliance."
        ],
        "acceptanceCriteria": [
          "Given the user opens the dashboard and connected appliances exist, when appliance data is loaded, then each connected appliance entry shows one current high-level status.",
          "Given a connected appliance is available, operating normally, or requires attention according to the data source, when the dashboard is displayed, then the displayed high-level status communicates that corresponding condition.",
          "Given multiple connected appliances exist with different statuses, when the dashboard is displayed, then each appliance entry shows the status belonging to that specific appliance.",
          "Given the status of an appliance changes and the dashboard is refreshed or synchronized, then the displayed status for that appliance reflects the latest retrieved status.",
          "Given the status for an appliance cannot be retrieved, when the dashboard is displayed, then that appliance entry shows a status-unavailable indicator rather than an empty or misleading status."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as one atomic requirement for dashboard status visibility, including traceable status categories, per-appliance association, update behavior, and exception handling for unavailable status data."
      },
      {
        "sourceRowNumber": 4,
        "sourceId": "PR_BAROLO_2.1",
        "id": "SR_BAROLO_2.1",
        "text": "The app shall display the current temperature and unit of measure for each temperature-controlled zone of each connected appliance on the dashboard.",
        "happyFlow": "When the dashboard is opened or refreshed, the app displays each temperature-controlled zone of every connected appliance with its current temperature and unit of measure.",
        "alternativeFlows": [
          "If a connected appliance has more than one temperature-controlled zone, the dashboard displays a separate current temperature and unit of measure for each zone.",
          "If current temperature values change after refresh or synchronization, the dashboard reflects the latest retrieved temperature values and units."
        ],
        "exceptionFlows": [
          "If the current temperature for a temperature-controlled zone cannot be retrieved, the dashboard displays a clearly distinguishable temperature-unavailable indicator for that zone while preserving the zone association."
        ],
        "acceptanceCriteria": [
          "Given the dashboard is opened and a connected appliance has at least one temperature-controlled zone, when temperature data is loaded, then each temperature-controlled zone shows a current temperature value and a unit of measure.",
          "Given a connected appliance has multiple temperature-controlled zones, when the dashboard is displayed, then each zone has its own displayed current temperature and unit of measure.",
          "Given multiple connected appliances have temperature-controlled zones, when the dashboard is displayed, then each displayed temperature is associated with the correct appliance and zone.",
          "Given a zone temperature or unit changes and the dashboard is refreshed or synchronized, then the displayed temperature and unit reflect the latest retrieved values.",
          "Given the current temperature for a zone cannot be retrieved, when the dashboard is displayed, then that zone shows a temperature-unavailable indicator instead of a blank or stale-looking value."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as a precise display requirement for current zone temperatures on the dashboard, preserving the source constraints of per-zone display and unit visibility."
      },
      {
        "sourceRowNumber": 5,
        "sourceId": "PR_BAROLO_3.1",
        "id": "SR_BAROLO_3.1.1",
        "text": "The app shall allow the user to turn on the Presenter light of a connected appliance from the dashboard quick actions.",
        "happyFlow": "From the dashboard, the user selects the quick action to turn on the Presenter light for a connected appliance, and the app sends the on command and shows the resulting on state after confirmation.",
        "alternativeFlows": [
          "If the Presenter light is already on, selecting the on quick action results in no contradictory state change and the dashboard continues to show the light as on."
        ],
        "exceptionFlows": [
          "If the connected appliance cannot receive or confirm the on command, the app notifies the user that the Presenter light could not be turned on and does not present the light as confirmed on."
        ],
        "acceptanceCriteria": [
          "Given a connected appliance supports a Presenter light and is shown on the dashboard, when the dashboard quick actions are available, then an action to turn on the Presenter light is available for that appliance.",
          "Given the Presenter light is off, when the user selects the dashboard quick action to turn it on, then the app sends a Presenter-light-on command for the selected appliance.",
          "Given the appliance confirms the Presenter-light-on command, then the dashboard reflects the Presenter light state as on for that appliance.",
          "Given the appliance does not receive or confirm the command, then the app displays a failure indication and does not show the Presenter light as confirmed on.",
          "Given multiple appliances are shown on the dashboard, when the user turns on the Presenter light using one appliance's quick action, then the command is applied only to that selected appliance."
        ],
        "score": 100,
        "issues": [],
        "rationale": "The on behavior was separated from the source on/off capability to keep the requirement atomic and directly testable for the dashboard quick-action flow."
      },
      {
        "sourceRowNumber": 5,
        "sourceId": "PR_BAROLO_3.1",
        "id": "SR_BAROLO_3.1.2",
        "text": "The app shall allow the user to turn off the Presenter light of a connected appliance from the dashboard quick actions.",
        "happyFlow": "From the dashboard, the user selects the quick action to turn off the Presenter light for a connected appliance, and the app sends the off command and shows the resulting off state after confirmation.",
        "alternativeFlows": [
          "If the Presenter light is already off, selecting the off quick action results in no contradictory state change and the dashboard continues to show the light as off."
        ],
        "exceptionFlows": [
          "If the connected appliance cannot receive or confirm the off command, the app notifies the user that the Presenter light could not be turned off and does not present the light as confirmed off."
        ],
        "acceptanceCriteria": [
          "Given a connected appliance supports a Presenter light and is shown on the dashboard, when the dashboard quick actions are available, then an action to turn off the Presenter light is available for that appliance.",
          "Given the Presenter light is on, when the user selects the dashboard quick action to turn it off, then the app sends a Presenter-light-off command for the selected appliance.",
          "Given the appliance confirms the Presenter-light-off command, then the dashboard reflects the Presenter light state as off for that appliance.",
          "Given the appliance does not receive or confirm the command, then the app displays a failure indication and does not show the Presenter light as confirmed off.",
          "Given multiple appliances are shown on the dashboard, when the user turns off the Presenter light using one appliance's quick action, then the command is applied only to that selected appliance."
        ],
        "score": 100,
        "issues": [],
        "rationale": "The off behavior was separated from the source on/off capability to keep command behavior, confirmation, and failure handling independently verifiable."
      },
      {
        "sourceRowNumber": 6,
        "sourceId": "PR_BAROLO_2.2",
        "id": "SR_BAROLO_2.2",
        "text": "The app shall display the current temperature and unit of measure for each wine zone of the selected connected appliance on the appliance detail page.",
        "happyFlow": "When the user opens the appliance detail page for a connected appliance with wine zones, the app displays each wine zone with its current temperature and unit of measure.",
        "alternativeFlows": [
          "If the selected appliance has multiple wine zones, the detail page displays a separate current temperature and unit of measure for each wine zone.",
          "If temperature values change after refresh or synchronization, the detail page reflects the latest retrieved temperature values and units."
        ],
        "exceptionFlows": [
          "If the current temperature for a wine zone cannot be retrieved, the detail page displays a clearly distinguishable temperature-unavailable indicator for that wine zone."
        ],
        "acceptanceCriteria": [
          "Given the user opens the detail page for a connected appliance with at least one wine zone, when temperature data is loaded, then each wine zone shows a current temperature value and a unit of measure.",
          "Given the selected appliance has multiple wine zones, when the detail page is displayed, then each wine zone has its own displayed current temperature and unit of measure.",
          "Given the current temperature or unit for a wine zone changes and the detail page is refreshed or synchronized, then the displayed temperature and unit reflect the latest retrieved values.",
          "Given the current temperature for a wine zone cannot be retrieved, when the detail page is displayed, then that wine zone shows a temperature-unavailable indicator instead of a blank or misleading value."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as one atomic detail-page display requirement for current wine-zone temperature and unit visibility, including multi-zone and unavailable-data behavior."
      },
      {
        "sourceRowNumber": 7,
        "sourceId": "PR_BAROLO_2.3",
        "id": "SR_BAROLO_2.3",
        "text": "The app shall allow the user to set the target temperature for each available wine zone on the appliance detail page to a valid value from 5°C to 20°C in 1°C increments.",
        "happyFlow": "On the appliance detail page, the user selects an available wine zone, chooses a valid target temperature, submits the change, and the app sends the target-temperature update for that zone.",
        "alternativeFlows": [
          "If the selected wine zone already has the chosen target temperature, the app does not create a contradictory change and the target temperature remains unchanged.",
          "If the appliance has multiple available wine zones, the user can set the target temperature independently for each zone."
        ],
        "exceptionFlows": [
          "If the user attempts to choose or submit a value below 5°C, above 20°C, or not aligned to a 1°C increment, the app prevents submission of that invalid value.",
          "If the appliance does not confirm the target-temperature update, the app notifies the user that the change failed and does not present the new value as confirmed."
        ],
        "acceptanceCriteria": [
          "Given the user opens the detail page for a connected appliance with an available wine zone, when the target temperature control is shown for that zone, then selectable or submittable values are limited to 5°C through 20°C inclusive.",
          "Given the target temperature control is shown, then valid values are available only in 1°C increments.",
          "Given the user selects a valid target temperature for a wine zone and submits the change, when the appliance confirms the update, then the app displays the selected value as the current target temperature for that wine zone.",
          "Given the appliance has multiple available wine zones, when the user changes the target temperature for one zone, then the command identifies that zone and does not change the target temperature of another zone.",
          "Given the user attempts to submit a value less than 5°C, greater than 20°C, or not in a 1°C increment, then the app rejects or prevents the submission and no target-temperature update command is sent for that invalid value.",
          "Given the appliance fails to confirm a submitted valid target-temperature update, then the app displays a failure indication and does not show the submitted value as confirmed for that zone."
        ],
        "score": 100,
        "issues": [],
        "rationale": "Derived as a single cohesive adjustment requirement because the range and increment are inseparable validation constraints for the target-temperature setting behavior; acceptance criteria make the constraints and exception handling directly testable."
