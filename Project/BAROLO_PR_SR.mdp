    "softwareRequirements": [
      {
        "sourceRowNumber": 2,
        "sourceId": "PR_BAROLO_1.1",
        "id": "SR_BAROLO_1.1",
        "text": "The app dashboard shall display the product-defined appliance type name for the currently selected appliance to users who have access to that appliance; if the appliance type for the selected appliance cannot be determined, the dashboard shall display a clear 'appliance type unavailable' indication and shall not display a blank, incorrect, or previously selected appliance type value.",
        "happyFlow": "Given a user with access selects an appliance and opens the dashboard, when the app retrieves the appliance metadata, then the dashboard displays the product-defined appliance type name for that selected appliance.",
        "alternativeFlows": [
          "Given the user switches to another accessible appliance while viewing the dashboard, when the dashboard context changes, then the displayed appliance type updates to the product-defined appliance type name of the newly selected appliance."
        ],
        "exceptionFlows": [
          "Given the appliance type is missing, unknown, or cannot be retrieved, when the dashboard is displayed, then the dashboard shows a clear unavailable indication for appliance type and does not show an empty, misleading, stale, or incorrect value."
        ],
        "acceptanceCriteria": [
          "Given an accessible appliance with a known product-defined appliance type, when the user opens the dashboard for that appliance, then the appliance type field is visible on the dashboard.",
          "Given the appliance type field is visible, when the selected appliance is appliance A, then the displayed value equals the product-defined appliance type name returned for appliance A.",
          "Given the user changes the selected appliance from appliance A to appliance B, when the dashboard refreshes its context, then the displayed appliance type corresponds to appliance B and not appliance A.",
          "Given the selected appliance has no determinable appliance type, when the dashboard is displayed, then the appliance type field shows an explicit unavailable indication.",
          "Given the selected appliance has no determinable appliance type, when the dashboard is displayed, then the appliance type field is not blank and does not show a value from another appliance."
        ],
        "score": 93,
        "issues": [],
        "rationale": "The derived requirement is clear, atomic, traceable, observable, and testable using controlled appliance metadata. It adds explicit selected-appliance binding and unavailable-state behavior required for reliable use-case and test-case derivation."
