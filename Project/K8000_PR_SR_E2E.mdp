          },
          {
            "stepNumber": 2,
            "action": "Open the app dashboard for the test user.",
            "expectedResult": "The dashboard loads successfully."
          },
          {
            "stepNumber": 3,
            "action": "Locate the 'Pantry Cooler' appliance entry on the dashboard.",
            "expectedResult": "The appliance entry remains visible and is not removed due to the missing type."
          },
          {
            "stepNumber": 4,
            "action": "Inspect the type field on the 'Pantry Cooler' entry.",
            "expectedResult": "The type field shows the defined fallback text 'Type unavailable' and does not show an empty field, a numeric placeholder, 'Refrigerator', 'Freezer', or any other incorrect appliance type."
          }
        ],
        "score": 100,
        "issues": [],
        "rationale": "Covers unavailable source data handling with explicit fallback verification and guards against empty, misleading, or incorrect labels."
      },
