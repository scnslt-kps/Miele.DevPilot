    "e2eTests": [
      {
        "sourceId": "SR_REQ_1.1.1",
        "sourcePrId": "PR_REQ_1.1",
        "id": "E2E_REQ_1.1.1.1",
        "group": "Dashboard / Cooling appliance type labels",
        "description": "Display correct manufacturer-defined appliance type labels for multiple supported cooling appliances without cross-assignment.",
        "coveredAcceptanceCriteria": [
          "Given the dashboard contains a supported connected cooling appliance with a manufacturer-defined appliance type, when the dashboard is displayed, then the appliance tile or list entry shows that appliance type as a readable text label.",
          "Given the dashboard contains multiple supported connected cooling appliances with different manufacturer-defined appliance types, when the dashboard is displayed, then each appliance shows its own appliance type label and no label is assigned to the wrong appliance."
        ],
        "preconditions": [
          "A test user is registered, authenticated in the app, and has permission to view all appliances in the test home.",
          "The app is installed, network connectivity is available, and the dashboard feature for supported connected cooling appliances is enabled.",
          "The appliance data source is controllable for the test home and contains exactly two supported connected cooling appliances assigned to the authenticated user.",
          "Appliance A and Appliance B are online or otherwise retrievable by the dashboard service.",
          "The dashboard cache for the test user is cleared before execution or the app is started in a fresh session."
        ],
        "testData": [
          "Appliance A id: cool-fridge-001, display name: Kitchen Fridge, manufacturer-defined appliance type: Refrigerator.",
          "Appliance B id: cool-freezer-001, display name: Garage Freezer, manufacturer-defined appliance type: Freezer.",
          "Expected labels are rendered as human-readable text on each appliance tile or list entry."
        ],
        "steps": [
          {
            "stepNumber": 1,
            "action": "Configure the appliance data source so Appliance A has type 'Refrigerator' and Appliance B has type 'Freezer'.",
            "expectedResult": "The data source stores Appliance A with type 'Refrigerator' and Appliance B with type 'Freezer' for the authenticated user's home."
          },
          {
            "stepNumber": 2,
            "action": "Launch the app and sign in as the test user if not already signed in.",
            "expectedResult": "The app opens successfully and the authenticated user's home context is active."
          },
          {
            "stepNumber": 3,
            "action": "Navigate to the dashboard.",
            "expectedResult": "The dashboard is displayed and contains one visible entry for 'Kitchen Fridge' and one visible entry for 'Garage Freezer'."
          },
          {
            "stepNumber": 4,
            "action": "Inspect the visible type label on the 'Kitchen Fridge' entry.",
            "expectedResult": "The 'Kitchen Fridge' entry shows the readable type label 'Refrigerator'."
          },
          {
            "stepNumber": 5,
            "action": "Inspect the visible type label on the 'Garage Freezer' entry.",
            "expectedResult": "The 'Garage Freezer' entry shows the readable type label 'Freezer'."
          },
          {
            "stepNumber": 6,
            "action": "Compare the type labels on both appliance entries.",
            "expectedResult": "No label is assigned to the wrong appliance: 'Kitchen Fridge' does not show 'Freezer' and 'Garage Freezer' does not show 'Refrigerator'."
          }
        ],
        "score": 100,
        "issues": [],
        "rationale": "Covers single and multiple appliance label rendering with explicit verification that labels are readable and not cross-assigned between appliances."
      },
      {
        "sourceId": "SR_REQ_1.1.1",
        "sourcePrId": "PR_REQ_1.1",
        "id": "E2E_REQ_1.1.1.2",
        "group": "Dashboard / Cooling appliance type labels",
        "description": "Refresh dashboard after appliance type changes and show the updated manufacturer-defined type label.",
        "coveredAcceptanceCriteria": [
          "Given the manufacturer-defined appliance type for an appliance changes in the appliance data source, when the dashboard data is refreshed, then the dashboard displays the updated appliance type label for that appliance."
        ],
        "preconditions": [
          "A test user is authenticated and has permission to view the test home.",
          "The dashboard feature for supported connected cooling appliances is enabled.",
          "The appliance data source is controllable and contains one supported connected cooling appliance assigned to the user.",
          "The appliance is visible on the dashboard and its initial manufacturer-defined type can be updated in the data source during the test.",
          "Network connectivity is available between app, backend, and appliance data source."
        ],
        "testData": [
          "Appliance id: cool-combi-001, display name: Utility Cooling Appliance.",
          "Initial manufacturer-defined appliance type: Refrigerator.",
          "Updated manufacturer-defined appliance type: Fridge-Freezer Combination."
        ],
        "steps": [
          {
            "stepNumber": 1,
            "action": "Configure the appliance data source so 'Utility Cooling Appliance' has manufacturer-defined appliance type 'Refrigerator'.",
            "expectedResult": "The data source confirms the appliance type is 'Refrigerator'."
          },
          {
            "stepNumber": 2,
            "action": "Open the app dashboard for the test user.",
            "expectedResult": "The dashboard shows 'Utility Cooling Appliance' with type label 'Refrigerator'."
          },
          {
            "stepNumber": 3,
            "action": "Change the appliance type in the appliance data source to 'Fridge-Freezer Combination'.",
            "expectedResult": "The data source confirms the updated type value 'Fridge-Freezer Combination' for the same appliance id."
          },
          {
            "stepNumber": 4,
            "action": "Trigger a dashboard data refresh using the app's standard refresh mechanism.",
            "expectedResult": "The dashboard completes refresh without an error message."
          },
          {
            "stepNumber": 5,
            "action": "Inspect the type label for 'Utility Cooling Appliance' after refresh.",
            "expectedResult": "The appliance remains visible and its type label is updated to 'Fridge-Freezer Combination'; the old label 'Refrigerator' is no longer displayed for that appliance."
          }
        ],
        "score": 100,
        "issues": [],
        "rationale": "Verifies the required state transition from old to new manufacturer-defined appliance type and confirms persistence of the same appliance entry after refresh."
      },
      {
        "sourceId": "SR_REQ_1.1.1",
        "sourcePrId": "PR_REQ_1.1",
